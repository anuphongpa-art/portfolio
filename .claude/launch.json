{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--no-clipboard"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Static Site (Python http.server)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
